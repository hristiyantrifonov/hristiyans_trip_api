  [1m[36mTrip Create (6.8ms)[0m  [1m[32mINSERT INTO "trips" ("name", "image_url", "short_description", "long_description", "rating", "created_at", "updated_at") VALUES ('Mount Rushmore', 'https://images.unsplash.com/photo-1586974772928-9e4d0efcc9ab', 'Famous presidential monument carved into granite.', 'Sculpted into the Black Hills of South Dakota, Mount Rushmore features the faces of Washington, Jefferson, Roosevelt, and Lincoln. The monument took 14 years to complete and stands as a tribute to the nation’s founding, growth, and preservation.
', 4, '2026-03-22 17:41:56.283996', '2026-03-22 17:41:56.283996') RETURNING "id" /*application='HristiyansTripApi'*/[0m
