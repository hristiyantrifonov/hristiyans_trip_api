  [1m[36mTrip Create (70.7ms)[0m  [1m[32mINSERT INTO "trips" ("name", "image_url", "short_description", "long_description", "rating", "created_at", "updated_at") VALUES ('Grand Canyon National Park', 'https://images.unsplash.com/photo-1501785888041-af3ef285b470', 'Vast red rock canyon carved by the Colorado River.', 'Stretching 277 miles long and over a mile deep, the Grand Canyon reveals nearly two billion years of Earth''s history through its colorful layers of rock. Visitors can hike, raft, or simply take in the breathtaking views from the rim, watching the light shift across the canyon walls throughout the day.
